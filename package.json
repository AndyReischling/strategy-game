{
  "name": "sovereign-stack",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Sovereign Stack — a turn-based strategy game about building competing AI coalitions across a five-layer technology stack.",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"tsx watch server/index.ts\"",
    "client": "vite",
    "server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.3",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
